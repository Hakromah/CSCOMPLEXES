{
  "kind": "collectionType",
  "collectionName": "school_exams",
  "info": {
    "singularName": "school-exam",
    "pluralName": "school-exams",
    "displayName": "School Exam"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "default": "Exam"
    },
    "date": {
      "type": "date",
      "required": true
    },
    "startTime": {
      "type": "time",
      "required": true
    },
    "endTime": {
      "type": "time",
      "required": true
    },
    "term": {
      "type": "string"
    },
    "semester": {
      "type": "string",
      "required": true
    },
    "academicYear": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::academic-year.academic-year",
      "inversedBy": "exams"
    },
    "semesterRel": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::semester.semester",
      "inversedBy": "exams"
    },
    "termRel": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::term.term",
      "inversedBy": "exams"
    },
    "weight": {
      "type": "integer"
    },
    "closed": {
      "type": "boolean",
      "default": false
    },
    "locked": {
      "type": "boolean",
      "default": false
    },
    "classe": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::school-class.school-class"
    },
    "teacher": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "subject": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subject.subject"
    }
  }
}
